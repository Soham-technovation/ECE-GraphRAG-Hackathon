# Optional: Set to use OpenAI for answer generation and judging
# If not set, defaults to extractive/HuggingFace models (free)
# OPENAI_API_KEY=sk-your-key-here

# Optional: Override default embedding model
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Override default judge model
# JUDGE_MODEL=google/flan-t5-small

# Optional: Data directory for custom datasets
# DATA_DIR=./data

# Optional: Graph output path
# GRAPH_PATH=./ECEGraphAI/graph/ece_graph.gpickle

# Optional: ChromaDB directory
# CHROMA_DB_PATH=./ECEGraphAI/chroma_db
